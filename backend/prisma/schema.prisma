generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id          String       @id @default(cuid())
  telegramId  String       @unique
  createdAt   DateTime     @default(now())
  words       Word[]
  collections Collection[]
}

model Collection {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  createdAt DateTime @default(now())
  words     Word[]   @relation("CollectionWords")

  @@unique([userId, name])
  @@index([userId])
}

model Word {
  id           String    @id @default(cuid())
  userId       String
  user         User      @relation(fields: [userId], references: [id])
  word         String
  sourceLang   String    @default("en")
  targetLang   String    @default("zh")
  phonetic     String?
  partOfSpeech String?
  meaningZh    String?
  collocations String[]
  synonyms     String[]
  antonyms     String[]
  reviewCount  Int       @default(0)
  nextReviewAt DateTime?
  createdAt    DateTime  @default(now())
  examples     Example[]
  collections  Collection[] @relation("CollectionWords")

  @@unique([userId, word])
}

model ReviewEvent {
  id        String   @id @default(cuid())
  userId    String
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
}

model Example {
  id         String   @id @default(cuid())
  wordId     String
  word       Word     @relation(fields: [wordId], references: [id], onDelete: Cascade)
  sentenceEn String
  sentenceZh String
  sourceName String
  sourceUrl  String
  createdAt  DateTime @default(now())
}
