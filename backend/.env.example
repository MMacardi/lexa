# --- Database ---
# Local dev points at the Docker Compose Postgres (see docker-compose.yml).
# Host port is 5433 to avoid clashing with a native Postgres on 5432.
# In production this is replaced by Railway's managed connection string.
DATABASE_URL="postgresql://vocab:vocab@localhost:5433/vocab?schema=public"

# --- Server ---
PORT=3000

# --- LLM: Qwen (Alibaba Bailian) ---
BAILIAN_API_KEY=""
BAILIAN_BASE_URL="https://dashscope.aliyuncs.com/compatible-mode/v1"

# --- Search ---
TAVILY_API_KEY=""

# --- Telegram ---
TELEGRAM_BOT_TOKEN=""
